<Window x:Class="uga_chacka.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:uga_chacka"
        mc:Ignorable="d"
        Title="Озвучка книг" Height="650" Width="1000"
        MinHeight="400" MinWidth="640"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <local:TypeToIndexConverter x:Key="TypeToIndexConverter"/>
        <local:ListToStringConverter x:Key="ListToStringConverter"/>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Click"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Click"/>
        <CommandBinding Command="ApplicationCommands.Find" Executed="Find_Executed"/>
        <CommandBinding Command="ApplicationCommands.Replace" Executed="Replace_Executed"/>
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="ApplicationCommands.Open"/>
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
        <KeyBinding Key="F" Modifiers="Control" Command="ApplicationCommands.Find"/>
        <KeyBinding Key="H" Modifiers="Control" Command="ApplicationCommands.Replace"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══ MENU ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Command="ApplicationCommands.Open" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Открыть не Unicode">
                    <MenuItem Header="Кодировка 1251 (win)" Tag="1251" Click="OpenNonUnicode_Click"/>
                    <MenuItem Header="Кодировка 866 (DOS)" Tag="866" Click="OpenNonUnicode_Click"/>
                </MenuItem>
                <MenuItem Header="Открыть проект" Click="OpenProject_Click"/>
                <MenuItem Header="_Сохранить"  Command="ApplicationCommands.Save" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Сохранить проект" Click="SaveProject_Click"/>
                <Separator/>
                <MenuItem Header="_Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Действие">
                <MenuItem Header="Разрешить омографы" Click="ResolveHomographs_Click"/>
                <MenuItem Header="Расставить ударения" Click="ApplyStress_Click"/>
                <Separator/>
                <MenuItem Header="Поиск"  InputGestureText="Ctrl+F" Click="Search_Click"/>
                <MenuItem Header="Замена" InputGestureText="Ctrl+H" Click="Replace_Click"/>
                <Separator/>
                <MenuItem Header="Озвучить" Click="Voiceover_Click"/>
            </MenuItem>
        </Menu>

        <!-- ═══ STATUS BAR ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <!-- left section: text analysis statistics -->
            <StatusBarItem Padding="6,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Слов: "/>
                    <TextBlock x:Name="StatusWords" Text="—"/>
                    <TextBlock Text="   Предложений: " Margin="8,0,0,0"/>
                    <TextBlock x:Name="StatusSentences" Text="—"/>
                    <TextBlock Text="   Омографов: " Margin="8,0,0,0"/>
                    <TextBlock x:Name="StatusHomographCount" Text="—"/>
                    <Button x:Name="CancelResolutionBtn" 
                            Content="Отмена" 
                            Click="CancelResolutionBtn_Click"
                            Padding="8,2" Margin="12,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>
            </StatusBarItem>
            <Separator />
            <!-- right section: current homograph info during navigation -->
            <StatusBarItem Padding="6,0">
                <TextBlock x:Name="StatusCurrentHomograph"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ MAIN TABS ═══ -->
        <TabControl x:Name="MainTabs">

            <!-- ── Tab: Оригинал ── -->
            <TabItem Header="Оригинал">
                <TextBox x:Name="OriginalText"
                         AcceptsReturn="True"
                         AcceptsTab="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"
                         FontSize="14"
                         FontFamily="Segoe UI"
                         Padding="6"
                         PreviewMouseWheel="Text_PreviewMouseWheel"/>
            </TabItem>

            <!-- ── Tab: Результат ── -->
            <TabItem Header="Результат">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <ToolBarTray Grid.Row="0" IsLocked="True">
                        <ToolBar>
                            <Button x:Name="PrevHomographBtn"
                                    Content="◄ Предыдущий"
                                    IsEnabled="False"
                                    Padding="8,2"
                                    Click="PrevHomograph_Click"/>
                            <Separator/>
                            <TextBlock x:Name="HomographIndexText"
                                       VerticalAlignment="Center"
                                       Margin="2,0"
                                       MinWidth="30"
                                       TextAlignment="Center"/>
                            <Separator/>
                            <Button x:Name="NextHomographBtn"
                                    Content="Следующий ►"
                                    IsEnabled="False"
                                    Padding="8,2"
                                    Click="NextHomograph_Click"/>
                            <Separator/>
                            <TextBlock x:Name="ManualEditWarning"
                                       Foreground="Red"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"
                                       Visibility="Collapsed"
                                       Text="Омографы были модифицированы вручную, навигация может сбоить"/>
                        </ToolBar>
                        
                        <ToolBar x:Name="FindReplaceToolBar">
                            
                            <TextBox x:Name="FindTextBox" Width="180" Margin="0,0,6,0" KeyDown="FindTextBox_KeyDown"/>
                            <Button Content="Найти" Padding="5,2" Margin="0,0,8,0" Click="FindNext_Click"/>
                            <Separator/>
                            <TextBox x:Name="ReplaceTextBox" Width="180" Margin="0,0,6,0" KeyDown="ReplaceTextBox_KeyDown"/>
                            <Button Content="Заменить" Padding="5,2" Click="ReplaceNext_Click"/>
                        </ToolBar>
                        
                    </ToolBarTray>
                    <RichTextBox x:Name="ResultText"
                                 Grid.Row="1"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 FontSize="14"
                                 FontFamily="Segoe UI"
                                 Padding="6"
                                 AcceptsTab="True"
                                 TextChanged="ResultText_TextChanged"
                                 PreviewMouseWheel="Text_PreviewMouseWheel"/>
                </Grid>
            </TabItem>

            <!-- ── Tab: Настройки ── -->
            <TabItem Header="Настройки">
                <TabControl TabStripPlacement="Left">

                    <!-- LLM -->
                    <TabItem Header="LLM">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12" MaxWidth="480">
                                <TextBlock Text="Тип подключения" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LlmType" 
                                          Margin="0,0,0,12" 
                                          SelectedIndex="{Binding Llm.Type, Converter={StaticResource TypeToIndexConverter}, Mode=TwoWay}">
                                    <ComboBoxItem Content="OpenAI API"/>
                                    <ComboBoxItem Content="FoundryLocal"/>
                                </ComboBox>
                                <TextBlock Text="URL" Margin="0,0,0,4"/>
                                <TextBox x:Name="LlmUrl" Text="{Binding Llm.Url, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                                <TextBlock Text="Модель" Margin="0,0,0,4"/>
                                <TextBox x:Name="LlmModel" Text="{Binding Llm.Model, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>
                                <TextBlock Text="Модель для Foundry Local" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LlmFoundryModel" 
                                          Margin="0,0,0,12"
                                          SelectedItem="{Binding Llm.FoundryModel, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          DropDownOpened="LlmFoundryModel_DropDownOpened"/>
                                <TextBlock Text="API Key" Margin="0,0,0,4"/>
                                <PasswordBox x:Name="LlmApiKey" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Температура: "/>
                                    <TextBlock Text="{Binding Llm.Temperature, StringFormat=F1}"/>
                                </StackPanel>
                                <Slider x:Name="LlmTemperature"
                                        Value="{Binding Llm.Temperature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0" Maximum="2" 
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight"
                                        Margin="0,0,0,12"/>
                                <TextBlock Text="System Prompt" Margin="0,0,0,4"/>
                                <TextBox x:Name="LlmSystemPrompt"
                                         Text="{Binding Llm.SystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,20"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- TTS -->
                    <TabItem Header="TTS">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12" MaxWidth="480">
                                <TextBlock Text="F5-TTS CLI (путь к f5-tts_infer-cli)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseF5TtsCli_Click"/>
                                    <TextBox x:Name="TtsCliPath" Text="{Binding Tts.F5TtsCliPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Конфиг модели (.yaml)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseModelCfg_Click"/>
                                    <TextBox x:Name="TtsModelCfg" Text="{Binding Tts.ModelCfg, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Файл весов (.safetensors)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseCkptFile_Click"/>
                                    <TextBox x:Name="TtsCkptFile" Text="{Binding Tts.CkptFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Файл словаря (vocab.txt)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseVocabFile_Click"/>
                                    <TextBox x:Name="TtsVocabFile" Text="{Binding Tts.VocabFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Референсный аудиофайл (голос)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,12">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseVoice_Click"/>
                                    <TextBox x:Name="TtsVoicePath" Text="{Binding Tts.VoicePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Текст референсного аудио" Margin="0,0,0,4"/>
                                <TextBox x:Name="TtsRefText"
                                         Text="{Binding Tts.RefText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         Height="60"
                                         VerticalScrollBarVisibility="Auto"
                                         Margin="0,0,0,12"/>
                                <TextBlock Text="Устройство (cuda / cpu)" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Tts.Device, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,20"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Омографы -->
                    <TabItem Header="Омографы">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12" MaxWidth="480">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Порог вероятности: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Homograph.Threshold, StringFormat=F0}" FontWeight="SemiBold"/>
                                    <TextBlock Text="%" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Slider x:Name="HomographThreshold"
                                        Value="{Binding Homograph.Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight"
                                        Margin="0,0,0,20"/>
                                <TextBlock Text="Словарь омографов (dic.json)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseDic_Click"/>
                                    <TextBox x:Name="DicPath" Text="{Binding Homograph.DictionaryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Словари ударений" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32" Margin="4,0,0,0" Click="BrowseDicA_Click"/>
                                    <TextBox x:Name="DicAPath" Text="{Binding Homograph.DicAPath, Mode=TwoWay, Converter={StaticResource ListToStringConverter}, UpdateSourceTrigger=PropertyChanged}" Height="64" AcceptsReturn="True"/>
                                </DockPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Общие -->
                    <TabItem Header="Общие">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12" MaxWidth="480">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Размер шрифта по умолчанию: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding General.DefaultFontSize, StringFormat=F0}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" pt" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Slider x:Name="DefaultFontSize"
                                        Value="{Binding General.DefaultFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="8" Maximum="36"
                                        TickFrequency="2" IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight"
                                        Margin="0,0,0,20"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
