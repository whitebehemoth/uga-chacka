<Window x:Class="WhiteBehemoth.Yara.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:WhiteBehemoth.Yara.Converters"
        Title="Яра — Разметка ударений" Height="648" Width="1102"
        MinHeight="400" MinWidth="640"
        PreviewKeyDown="Window_PreviewKeyDown"
        Loaded="Window_Loaded">

    <Window.Resources>
        <converters:ListToStringConverter x:Key="ListToStringConverter"/>
    </Window.Resources>

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Open" Executed="Open_Click"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="Save_Click"/>
        <CommandBinding Command="ApplicationCommands.Find" Executed="ToggleFindReplace"/>
    </Window.CommandBindings>
    <Window.InputBindings>
        <KeyBinding Key="O" Modifiers="Control" Command="ApplicationCommands.Open"/>
        <KeyBinding Key="S" Modifiers="Control" Command="ApplicationCommands.Save"/>
        <KeyBinding Key="F" Modifiers="Control" Command="ApplicationCommands.Find"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ═══ MENU ═══ -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Открыть..." Command="ApplicationCommands.Open" InputGestureText="Ctrl+O"/>
                <MenuItem Header="Открыть не Unicode">
                    <MenuItem Header="Кодировка 1251 (win)" Tag="1251" Click="OpenNonUnicode_Click"/>
                    <MenuItem Header="Кодировка 866 (DOS)" Tag="866" Click="OpenNonUnicode_Click"/>
                </MenuItem>
                <MenuItem Header="Открыть проект" Click="OpenProject_Click"/>
                <MenuItem Header="_Сохранить" Command="ApplicationCommands.Save" InputGestureText="Ctrl+S"/>
                <MenuItem Header="Сохранить проект" Click="SaveProject_Click"/>
                <Separator/>
                <MenuItem Header="_Выход" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Обработка текста">
                <MenuItem Header="Ударения в омографы" Click="ResolveHomographs_Click"/>
                <MenuItem Header="Ударения в остальные слова" Click="ApplyStress_Click"/>
            </MenuItem>
            <MenuItem Header="Правка">
                <MenuItem Header="Найти / Заменить" Command="ApplicationCommands.Find" InputGestureText="Ctrl+F"/>
            </MenuItem>
        </Menu>

        <!-- ═══ STATUS BAR ═══ -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <DockPanel LastChildFill="True"/>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>
            <StatusBarItem Padding="6,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Слов: "/>
                    <TextBlock x:Name="StatusWords" Text="—"/>
                    <TextBlock Text="   Предложений: " Margin="8,0,0,0"/>
                    <TextBlock x:Name="StatusSentences" Text="—"/>
                    <TextBlock Text="   Омографов: " Margin="8,0,0,0"/>
                    <TextBlock x:Name="StatusHomographCount" Text="—"/>
                    <Button x:Name="CancelBtn"
                            Content="Отмена"
                            Click="CancelBtn_Click"
                            Padding="8,2" Margin="12,0,0,0"
                            Visibility="Collapsed"/>
                </StackPanel>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem Padding="6,0">
                <TextBlock x:Name="StatusInfo"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ═══ MAIN TABS ═══ -->
        <TabControl x:Name="MainTabs">

            <!-- ── Tab: Текст ── -->
            <TabItem Header="Текст">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Toolbar: threshold + homograph nav + clean rules -->
                    <ToolBarTray Grid.Row="0" IsLocked="False">
                        <ToolBar x:Name="EditHomo">
                            <TextBlock Text="Порог для проверки: " VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Homograph.Threshold, StringFormat='{}{0:F0}%'}" VerticalAlignment="Center" MinWidth="30"/>
                            <Slider x:Name="HomographThreshold"
                                    Value="{Binding Homograph.Threshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Minimum="0" Maximum="100" Width="100"
                                    TickFrequency="1" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"/>
                            <Separator/>
                            <Button x:Name="PrevBtn"
                                    Content="◄" IsEnabled="False" Padding="8,2"
                                    ToolTip="Предыдущий неуверенный омограф (Alt+W)"
                                    Click="PrevHomograph_Click"/>
                            <Separator/>
                            <TextBlock x:Name="HomographIndexText"
                                       VerticalAlignment="Center" Margin="2,0"
                                       MinWidth="60" TextAlignment="Center"
                                       ToolTip="Навигация по омографам. Alt+цифра — выбрать вариант. Alt+` — подтвердить текущий."/>
                            <Separator/>
                            <Button x:Name="NextBtn"
                                    Content="►" IsEnabled="False" Padding="8,2"
                                    ToolTip="Следующий неуверенный омограф (Alt+S)"
                                    Click="NextHomograph_Click"/>
                            <Separator/>
                            <ComboBox x:Name="CleanRulesComboBox"
                                      Width="220" Margin="0,0,6,0"
                                      IsEditable="True" IsReadOnly="True"
                                      IsTextSearchEnabled="False" StaysOpenOnEdit="True"
                                      Text="Очистка текста">
                                <ComboBox.ItemContainerStyle>
                                    <Style TargetType="ComboBoxItem">
                                        <EventSetter Event="PreviewMouseLeftButtonDown"
                                                     Handler="CleanRuleItem_PreviewMouseLeftButtonDown"/>
                                    </Style>
                                </ComboBox.ItemContainerStyle>
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Description}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Button Content="⚡" Padding="5,2" Click="ApplyCleanRules_Click"
                                    ToolTip="Применить выбранные модификаторы"/>
                        </ToolBar>
                    </ToolBarTray>

                    <!-- Toolbar: find / replace (hidden by default) -->
                    <ToolBarTray Grid.Row="1" IsLocked="False"
                                 x:Name="FindReplaceBar" Visibility="Collapsed">
                        <ToolBar>
                            <TextBlock Text="Найти: " VerticalAlignment="Center"/>
                            <TextBox x:Name="FindTextBox" Width="160"
                                     KeyDown="FindTextBox_KeyDown"/>
                            <Button Content="🔍" Padding="5,2" Margin="0,0,8,0"
                                    Click="FindNext_Click" ToolTip="Найти"/>
                            <Separator/>
                            <TextBlock Text="Заменить на: " VerticalAlignment="Center"/>
                            <TextBox x:Name="ReplaceTextBox" Width="160"
                                     KeyDown="ReplaceTextBox_KeyDown"/>
                            <Button Content="🔠" Padding="5,2"
                                    Click="ReplaceNext_Click" ToolTip="Заменить"/>
                        </ToolBar>
                    </ToolBarTray>

                    <!-- Text area with placeholder -->
                    <Grid Grid.Row="2">
                        <RichTextBox x:Name="TextEditor"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"
                                     FontSize="14" FontFamily="Segoe UI"
                                     Padding="6" AcceptsTab="True"
                                     TextChanged="TextEditor_TextChanged"
                                     PreviewMouseWheel="Text_PreviewMouseWheel"/>
                        <TextBlock x:Name="PlaceholderText"
                                   IsHitTestVisible="False"
                                   Foreground="Gray" FontSize="14" FontFamily="Segoe UI"
                                   VerticalAlignment="Top" Margin="12,8"
                                   TextWrapping="Wrap"
                                   Text="Откройте файл (Ctrl+O) или вставьте текст для начала работы.&#x0a;Далее: Обработка текста → Ударения в омографы.&#x0a;Навигация: Alt+S / Alt+W, выбор варианта: Alt+цифра, подтвердить: Alt+`"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ── Tab: Настройки ── -->
            <TabItem Header="Настройки">
                <TabControl TabStripPlacement="Top">

                    <!-- LLM -->
                    <TabItem Header="LLM для омографов">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12" MaxWidth="600">

                                <!-- Provider selection -->
                                <TextBlock Text="Активный провайдер" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <StackPanel Margin="0,0,0,16">
                                    <RadioButton x:Name="UseOpenAi" Content="OpenAI" GroupName="LlmProvider"
                                                 Checked="LlmProvider_Changed" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="ActiveOpenAiConfig" Margin="20,0,0,8"
                                              DisplayMemberPath="Name"
                                              SelectionChanged="ActiveOpenAiConfig_Changed"/>
                                    <RadioButton x:Name="UseFoundry" Content="Foundry Local" GroupName="LlmProvider"
                                                 Checked="LlmProvider_Changed" Margin="0,4,0,4"/>
                                    <DockPanel Margin="20,0,0,4">
                                        <Button DockPanel.Dock="Right" Content="↻" Padding="6,2" Margin="4,0,0,0"
                                                Click="RefreshFoundryModels_Click" ToolTip="Обновить список моделей"/>
                                        <ComboBox x:Name="ActiveFoundryModel"
                                                  DisplayMemberPath="DisplayText"
                                                  SelectionChanged="ActiveFoundryModel_Changed"/>
                                    </DockPanel>
                                </StackPanel>

                                <Separator Margin="0,0,0,12"/>

                                <!-- OpenAI configs editor -->
                                <Grid Margin="0,0,0,16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Конфигурации OpenAI" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Параметры" FontWeight="SemiBold" Margin="12,0,0,8"/>
                                    <StackPanel Grid.Row="1">
                                        <ListBox x:Name="OpenAiConfigList" Height="145"
                                                 DisplayMemberPath="Name"
                                                 SelectionChanged="OpenAiConfigList_SelectionChanged"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4">
                                            <Button Content="+" Padding="8,2" Margin="0,0,4,0"
                                                    Click="AddOpenAiConfig_Click"/>
                                            <Button Content="−" Padding="8,2"
                                                    Click="RemoveOpenAiConfig_Click"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="12,0,0,0"
                                                DataContext="{Binding SelectedItem, ElementName=OpenAiConfigList}">
                                        <TextBlock Text="Имя" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="URL" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="Модель" Margin="0,0,0,2"/>
                                        <TextBox Text="{Binding Model, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                        <TextBlock Text="API Key" Margin="0,0,0,2"/>
                                        <TextBox x:Name="OaiApiKey"
                                                 Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}"
                                                 Margin="0,0,0,8"/>
                                    </StackPanel>
                                </Grid>

                                <Separator Margin="0,0,0,12"/>

                                <!-- Shared LLM params -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Температура: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding Llm.Temperature, StringFormat=F1}"/>
                                </StackPanel>
                                <Slider Value="{Binding Llm.Temperature, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="0" Maximum="2"
                                        TickFrequency="0.1" IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight" Margin="0,0,0,16"/>

                                <TextBlock Text="System Prompt" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Llm.SystemPrompt, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True" TextWrapping="Wrap" Height="120"
                                         VerticalScrollBarVisibility="Auto"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- Общие -->
                    <TabItem Header="Общие">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="16,12" MaxWidth="480">
                                <TextBlock Text="Словарь омографов (dic.json)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32"
                                            Margin="4,0,0,0" Click="BrowseDic_Click"/>
                                    <TextBox x:Name="DicPath"
                                             Text="{Binding Homograph.DictionaryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <TextBlock Text="Словари ударений" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32"
                                            Margin="4,0,0,0" Click="BrowseDicA_Click"/>
                                    <TextBox x:Name="DicAPath"
                                             Text="{Binding Homograph.DicAPath, Mode=TwoWay, Converter={StaticResource ListToStringConverter}, UpdateSourceTrigger=PropertyChanged}"
                                             Height="64" AcceptsReturn="True"/>
                                </DockPanel>
                                <TextBlock Text="Файл правил очистки (clean.rex)" Margin="0,0,0,4"/>
                                <DockPanel Margin="0,0,0,8">
                                    <Button DockPanel.Dock="Right" Content="…" Width="32"
                                            Margin="4,0,0,0" Click="BrowseCleanRegex_Click"/>
                                    <TextBox x:Name="CleanRegexPath"
                                             Text="{Binding Homograph.CleanRegexPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                </DockPanel>
                                <Separator Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock Text="Размер шрифта: " FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding General.DefaultFontSize, StringFormat=F0}" FontWeight="SemiBold"/>
                                    <TextBlock Text=" pt" FontWeight="SemiBold"/>
                                </StackPanel>
                                <Slider Value="{Binding General.DefaultFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Minimum="8" Maximum="36"
                                        TickFrequency="2" IsSnapToTickEnabled="True"
                                        TickPlacement="BottomRight" Margin="0,0,0,20"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
